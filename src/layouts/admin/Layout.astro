---
// src/layouts/AdminLayout.astro
import '../../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Admin Panel | Libes" } = Astro.props;

// Ambil path saat ini untuk menandai menu yang aktif
const pathname = new URL(Astro.request.url).pathname;
---

<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900 flex min-h-screen">
    
    <aside class="w-64 bg-slate-900 text-slate-300 flex flex-col sticky top-0 h-screen border-r border-slate-800">
      <div class="p-6">
        <h2 class="text-2xl font-bold text-white tracking-tight">LIBES<span class="text-blue-500">.</span></h2>
        <p class="text-xs text-slate-500 mt-1 uppercase tracking-widest font-semibold">Admin Dashboard</p>
      </div>

      <nav class="flex-1 px-4 space-y-2 mt-4">
        <a 
          href="/admin/dashboard" 
          class={`flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${pathname === '/admin/dashboard' ? 'bg-blue-600 text-white' : 'hover:bg-slate-800'}`}
        >
          <span class="text-xl">📊</span> Dashboard
        </a>
        <a 
          href="/admin/posts" 
          class={`flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${pathname.includes('/admin/posts') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800'}`}
        >
          <span class="text-xl">📝</span> Kelola Konten
        </a>
        <a 
          href="/admin/settings" 
          class={`flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${pathname.includes('/admin/settings') ? 'bg-blue-600 text-white' : 'hover:bg-slate-800'}`}
        >
          <span class="text-xl">⚙️</span> Pengaturan
        </a>
      </nav>

      <div class="p-4 border-t border-slate-800">
        <form method="POST" action="/admin/logout">
          <button 
            type="submit" 
            class="w-full flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-red-500/10 hover:text-red-300 rounded-lg transition-all font-medium"
          >
            <span class="text-xl">🚪</span> Keluar Akun
          </button>
        </form>
      </div>
    </aside>

    <main class="flex-1 flex flex-col">
      <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 sticky top-0 z-10">
        <h1 class="font-semibold text-slate-700">{title}</h1>
        <div class="flex items-center gap-4">
          <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-xs">
            AD
          </div>
          <span class="text-sm font-medium text-slate-600">Administrator</span>
        </div>
      </header>

      <div class="p-8">
        <slot />
      </div>
    </main>

  </body>
</html>