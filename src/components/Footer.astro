---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer
  id="footer"
  class="relative bg-slate-950 text-white pt-20 pb-10 px-4 sm:px-6 overflow-hidden"
>
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-blue-500/20 to-transparent"></div>

  <div class="container mx-auto max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 mb-16">
      
      <div class="md:col-span-1">
        <h3 class="text-2xl font-bold font-heading mb-6 text-white tracking-tight">
          LIBES<span class="text-blue-500">.</span>
        </h3>
        <p class="text-sm text-slate-400 mb-6 leading-relaxed max-w-sm">
          Ruang temu alternatif untuk merawat nalar dan menjalin kedekatan.
          Baca, diskusi, dan bergerak bersama di Brebes.
        </p>
        <div class="space-y-3 text-sm text-slate-500">
          <p class="flex items-center gap-3">
            <span class="text-blue-500">📍</span> Limbangan Kulon, Brebes, Jawa Tengah
          </p>
          <p class="flex items-center gap-3">
            <span class="text-blue-500">✉️</span> literasibrebesan@gmail.com
          </p>
        </div>
      </div>

      <div class="md:col-span-1 md:pl-10">
        <h4 class="text-xs font-bold mb-6 text-amber-400 uppercase tracking-[0.2em]">
          Navigasi
        </h4>
        <ul class="space-y-4 text-sm text-slate-400">
          <li>
            <a href="/" class="hover:text-blue-400 transition-colors flex items-center gap-2 group">
              <span class="w-0 group-hover:w-2 h-px bg-blue-400 transition-all"></span> Beranda
            </a>
          </li>
          <li>
            <a href="#agenda" class="hover:text-blue-400 transition-colors flex items-center gap-2 group">
              <span class="w-0 group-hover:w-2 h-px bg-blue-400 transition-all"></span> Agenda
            </a>
          </li>
          <li>
            <a href="/dokumentasi" class="hover:text-blue-400 transition-colors flex items-center gap-2 group">
              <span class="w-0 group-hover:w-2 h-px bg-blue-400 transition-all"></span> Galeri
            </a>
          </li>
          <li>
            <a href="/karya" class="hover:text-blue-400 transition-colors flex items-center gap-2 group">
              <span class="w-0 group-hover:w-2 h-px bg-blue-400 transition-all"></span> Karya & Zine
            </a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-1">
        <h4 class="text-xs font-bold mb-6 text-amber-400 uppercase tracking-[0.2em]">
          Sapa Kami
        </h4>
        <p class="text-sm text-slate-400 mb-6">
          Pantau terus pergerakan dan agenda terbaru kita lewat media sosial resmi.
        </p>

        <div class="flex items-center gap-3">
          <a
            href="https://www.instagram.com/literasi_brebesan/"
            target="_blank"
            class="w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-300 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-all group"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect height="20" rx="5" ry="5" width="20" x="2" y="2" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
            </svg>
          </a>

          <a
            href="https://wa.me/628993986415"
            target="_blank"
            class="w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-300 hover:bg-green-600 hover:text-white hover:border-green-600 transition-all"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </a>

          <a
            href="https://www.facebook.com/share/19FgN2ekpd/"
            target="_blank"
            class="w-11 h-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-300 hover:bg-blue-800 hover:text-white hover:border-blue-800 transition-all"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row items-center justify-between gap-6 text-[11px] uppercase tracking-[0.1em] text-slate-500 font-bold">
      <p>&copy; {year} Literasi Brebesan. Merawat Nalar, Menjalin Kedekatan.</p>
      <div class="flex items-center gap-6">
        <a href="/login" class="hover:text-blue-400 transition-colors uppercase">Admin Access</a>
        <p>
          Handcrafted with <span class="text-red-500">❤️</span> by 
          <a href="/" class="text-slate-300 hover:text-blue-400 transition-colors underline decoration-blue-500/30 underline-offset-4">Local Collective</a>
        </p>
      </div>
    </div>
  </div>
</footer>