<header class="relative" >
  <nav
    id="main-nav"
    class="fixed top-3 inset-x-3 md:inset-x-6 z-[60] max-w-7xl mx-auto bg-white/80 backdrop-blur-md border border-slate-200/50 shadow-sm rounded-2xl transition-all duration-300"
  >
    <div class="px-4 sm:px-6">
      <div class="flex justify-between items-center h-14">
        <a href="/" class="flex items-center gap-2 group">
          <img
            src="/literasi-brebesan.webp"
            alt="Logo"
            class="w-7 h-7 rounded-full border border-slate-100"
          />
          <div class="flex flex-col leading-none">
            <span
              class="font-black text-[10px] uppercase tracking-tighter text-slate-800"
              >Literasi</span
            >
            <span class="font-bold text-[10px] text-blue-600">Brebesan</span>
          </div>
        </a>

        <div class="hidden md:flex items-center gap-1">
          {
            ["Beranda", "Galeri", "Karya"].map((item) => (
              <a
                href={
                  item === "Beranda" ? "/" : `#${item.toLowerCase()}`
                }
                class="px-3 py-1.5 text-[11px] font-bold text-slate-600 hover:text-blue-600 rounded-lg transition-all"
              >
                {item}
              </a>
            ))
          }
          <a
            href="https://wa.me/628993986415"
            target="_blank"
            class="ml-2 bg-slate-900 text-white px-4 py-1.5 rounded-full text-[10px] font-bold hover:bg-blue-600 transition-all"
          >
            Gabung
          </a>
        </div>

        <button
          id="mobile-menu-button"
          class="md:hidden w-8 h-8 flex items-center justify-center bg-slate-50 text-slate-900 rounded-lg"
        >
          <div class="flex flex-col gap-1 w-3.5">
            <span
              id="l1"
              class="w-full h-0.5 bg-current rounded-full transition-all"
            ></span>
            <span
              id="l2"
              class="w-full h-0.5 bg-current rounded-full transition-all"
            ></span>
          </div>
        </button>
      </div>
    </div>
  </nav>

  <div
    id="drawer-overlay"
    class="fixed inset-0 bg-slate-950/10 backdrop-blur-[1px] z-[80] hidden opacity-0 transition-opacity duration-300"
  >
  </div>

  <aside
    id="mobile-menu"
    class="fixed top-20 right-2  w-[200px] bg-white z-[90] translate-x-[110%] transition-transform duration-300 ease-in-out shadow-2xl rounded-2xl border border-slate-100 flex flex-col"
  >
    <div class="p-5 flex flex-col h-auto">
      <div class="mb-6 pt-2">
        <span
          class="text-[9px] font-black text-slate-400 uppercase tracking-[0.2em]"
          >Menu</span
        >
      </div>

      <nav class="flex flex-col gap-1">
        {
          [
            { name: "Beranda", href: "/" },
            { name: "Galeri", href: "/dokumentasi" },
            { name: "Karya", href: "/karya" },
          ].map((link) => (
            <a
              href={link.href}
              class="px-3 py-2.5 text-xs font-bold text-slate-700 hover:bg-blue-50 hover:text-blue-600 rounded-xl transition-all"
            >
              {link.name}
            </a>
          ))
        }
      </nav>

      <div class="mt-5">
        <a
          href="https://wa.me/628993986415"
          target="_blank"
          class="flex items-center justify-center bg-blue-600 text-white py-3 rounded-xl text-[10px] font-bold"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </aside>
</header>
