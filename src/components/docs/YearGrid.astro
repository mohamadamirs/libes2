---
// src/components/docs/FolderGrid.astro
import Icon from './Icon.astro';
const { items = [], baseUrl } = Astro.props;
---
<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  {items.map((item) => (
    <a 
      href={`${baseUrl}${item.id}`} 
      class="flex items-center gap-4 p-4 bg-white border border-slate-200 rounded-2xl hover:border-blue-600 hover:bg-blue-50/50 transition-all group shadow-sm"
    >
      <div class="text-slate-300 group-hover:text-amber-500 transition-colors shrink-0">
        <Icon name="folder" class="w-8 h-8" />
      </div>
      <div class="flex flex-col overflow-hidden">
        <span class="text-sm font-bold text-slate-700 truncate group-hover:text-blue-700">{item.name}</span>
        <span class="text-[9px] text-slate-400 font-black uppercase tracking-tighter text-left">Buka Folder</span>
      </div>
    </a>
  ))}
</div>