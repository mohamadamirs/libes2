---
// src/components/docs/FolderGrid.astro
import Icon from './Icon.astro';

// Kita tambahkan prop 'type' untuk membedakan label jika diperlukan di masa depan
const { items = [], baseUrl, type = "folder" } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  {items.map((item) => (
    <a 
      href={`${baseUrl}${item.id}`} 
      class="flex items-center gap-4 p-4 bg-white border border-slate-200 rounded-2xl hover:border-blue-600 hover:bg-blue-50/50 transition-all group shadow-sm"
    >
      <div class="text-slate-300 group-hover:text-amber-500 transition-colors shrink-0">
        <Icon name={type === 'year' ? 'folder' : 'folder'} class="w-8 h-8" />
      </div>
      <div class="flex flex-col overflow-hidden text-left">
        <span class="text-sm font-bold text-slate-700 truncate group-hover:text-blue-700">
          {item.name}
        </span>
        <span class="text-[9px] text-slate-400 font-black uppercase tracking-tighter">
          {type === 'year' ? 'Lihat Arsip Tahun' : 'Buka Folder'}
        </span>
      </div>
    </a>
  ))}
</div>