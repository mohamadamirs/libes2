---
import Icon from "./Icon.astro";
const { activeYear } = Astro.props;
---

<aside class="hidden md:flex w-56 flex-col border-r border-slate-100 p-3 gap-1">
  <div
    class="mb-6 px-3 pt-2 font-black text-[10px] text-slate-400 uppercase tracking-widest"
  >
    Drive Saya
  </div>
  <!-- Cari bagian menu Beranda di Sidebar.astro -->
  <a
    href="/dokumentasi"
    class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-100 transition-all group"
  >
    <div
      class="shrink-0 text-slate-400 group-hover:text-blue-600 transition-colors"
    >
      <!-- Pastikan ada class w-5 h-5 atau w-6 h-6 di sini -->
      <Icon name="folder" class="w-6 h-6" />
    </div>
    <span class="text-sm font-bold text-slate-600 group-hover:text-slate-900"
      >Beranda</span
    >
  </a>
</aside>

<nav
  class="md:hidden fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-md border-t border-slate-100 flex justify-around py-2 z-50"
>
  <a
    href="/dokumentasi"
    class="flex flex-col items-center gap-0.5 text-blue-600"
  >
    <Icon name="folder" class="w-5 h-5" />
    <span class="text-[8px] font-black uppercase">File</span>
  </a>
</nav>
